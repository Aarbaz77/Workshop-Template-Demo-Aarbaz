{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true,
    "node": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-param-reassign": "warn",
    "func-names": "off"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.js",
        "**/*.spec.js"
      ],
      "env": {
        "jest": true
      }
    }
  ]
}
